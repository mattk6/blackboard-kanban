{
  "manifest_version": 3,
  "name": "Blackboard Organizer Extension",
  "version": "0.1.0",
  "description": "Transform Blackboard assignments into an organized Kanban workflow with automated backlog, and progress tracking.",
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Blackboard Kanban",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.blackboard.com/*",
        "*://*.cune.edu/*"
      ],
      "run_at": "document_idle",
      "js": [
        "contentScript.js"
      ]
    }
  ]
}